# ===========================================
# BBBBB 百家乐分析预测系统 - 环境变量配置
# 复制此文件为 .env 并根据实际环境修改
# ===========================================

# --- 基础运行配置 ---
# 运行环境（生产部署必须保持 production）
ENVIRONMENT=production
# 后端服务绑定的 IP 和端口（默认 0.0.0.0:8001）
HOST=0.0.0.0
BACKEND_PORT=8001
# 调试模式（生产环境必须设为 false）
DEBUG=false

# --- 数据库配置 ---
# 生产环境请使用独立数据库服务，不要使用本地 SQLite
DATABASE_URL=postgresql+asyncpg://app_user:change-this-password@db.example.internal:5432/baccarat

# --- 安全配置（生产环境必须修改！）---
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
AI_CONFIG_ENCRYPTION_KEY=your-ai-config-encryption-key-change-this-in-production
CORS_ORIGINS=https://frontend.example.com
ADMIN_DEFAULT_PASSWORD=YourSecurePassword123!

# --- AI API 配置 - 三模型专用 ---
# OpenAI API - 庄模型专用 (概率推理型)
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_BASE=https://api.openai.com/v1

# Anthropic API - 闲模型专用 (逻辑严谨型)
ANTHROPIC_API_KEY=sk-ant-your-claude-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_BASE=https://api.anthropic.com/v1

# Google Gemini API - 综合模型专用 (整合决策型)
GEMINI_API_KEY=AIzaSy-your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta

# 单 AI 模式 - DeepSeek V4 Pro
SINGLE_AI_API_KEY=sk-your-single-ai-api-key-here
SINGLE_AI_MODEL=deepseek-v4-pro
SINGLE_AI_API_BASE=

# API代理配置 (可选，中国用户建议使用)
OFOX_API_BASE=https://api.ofox.ai
OFOX_API_KEY=your-ofox-api-key-here
