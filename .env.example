# ============================================
# BBBBB - Docker/生产 环境变量
# 复制此文件为 .env 并修改值
# ===========================================

# ---- 运行环境（生产部署必须保持 production）----
ENVIRONMENT=production

# ---- 调试（生产必须 false）----
DEBUG=false

# ---- 后端暴露端口 ----
BACKEND_PORT=8001

# ===== 安全配置（生产环境必改！）=====
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
AI_CONFIG_ENCRYPTION_KEY=your-ai-config-encryption-key-change-this-in-production
CORS_ORIGINS=https://frontend.example.com
ADMIN_DEFAULT_PASSWORD=YourSecurePassword123!

# ---- 三模型AI API配置 ---
# 庄模型：GPT-4o mini（概率推理型）
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# 闲模型：Claude Sonnet 4（逻辑严谨型）
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# 综合模型：Gemini 1.5 Flash（整合决策型）
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# 单 AI 模式：DeepSeek V4 Pro
SINGLE_AI_API_KEY=sk-your-single-ai-api-key-here
SINGLE_AI_MODEL=deepseek-v4-pro
SINGLE_AI_API_BASE=

# API代理配置 (可选，中国用户建议使用)
OFOX_API_BASE=https://api.ofox.ai
OFOX_API_KEY=your-ofox-api-key-here
